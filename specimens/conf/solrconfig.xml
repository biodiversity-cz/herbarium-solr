<config>

    <luceneMatchVersion>10.4.0</luceneMatchVersion>

    <!-- request handler -->
    <requestHandler name="/select" class="solr.SearchHandler">
        <lst name="defaults">
            <str name="defType">edismax</str>
            <str name="qf">scientific_name^10 genus^6 family^4 title^3 text</str>
            <str name="pf">scientific_name^20</str>
            <str name="df">text</str>
        </lst>
    </requestHandler>

    <!-- autocomplete -->
    <requestHandler name="/suggest" class="solr.SearchHandler">
        <lst name="defaults">
            <str name="qf">scientific_name_suggest collector_suggest</str>
        </lst>
    </requestHandler>

    <!--  commit je potřeba volat je po velkých akcích, třeba po bulk update  -->
    <!--    je ve vyhledávání, jen ještě není na disku -->
    <autoSoftCommit>
        <maxTime>2000</maxTime>
    </autoSoftCommit>
    <!-- nová data se zapíší i na disk -->
    <autoCommit>
        <maxTime>60000</maxTime>
    </autoCommit>
